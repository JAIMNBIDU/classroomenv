# docker/Dockerfile.web
#
# Web Pentesting profile, built on top of classroomenv:core.
# Tools: ffuf, gobuster, feroxbuster, seclists, httpx, nikto, sqlmap, wpscan, whatweb, nuclei, dirsearch (burpsuite/zaproxy GUI excluded)
#
# Build (classroomenv:core must exist first):
#   docker build -f docker/Dockerfile.core -t classroomenv:core .
#   docker build -f docker/Dockerfile.web -t classroomenv:web .
#
# Run:
#   docker run -it --rm classroomenv:web

FROM classroomenv:core

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /opt/classroomenv

RUN python3 classroomenv.py install web --no-gui && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /root
CMD ["/bin/bash"]
